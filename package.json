{
	"name": "electrobun-tailwind-vanilla",
	"version": "1.0.0",
	"type": "module",
	"description": "Electrobun app with Tailwind CSS and vanilla TypeScript",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build:canary": "vite build && electrobun build --env=canary"
	},
	"dependencies": {
		"electrobun": "1.14.4"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.2.1",
		"@types/bun": "^1.3.10",
		"concurrently": "^9.2.1",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	}
}
